# Copy to apps/api/.env (API) and apps/web/.env.local (web) as noted.

# --- API (apps/api/.env) ---
# Local Postgres via Homebrew; replace USER with your macOS username (e.g. output of `whoami`).
DATABASE_URL="postgresql://USER@localhost:5432/jrst_dev?schema=public"
REDIS_URL="redis://localhost:6379"
SESSION_SECRET="dev-only-change-me"
NODE_ENV="development"
PORT=4000
WEB_ORIGIN="http://localhost:3000"

# --- Web (apps/web/.env.local) ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
PAYMENTS_WEBHOOK_SECRET="dev-webhook-secret"
API_ORIGIN="http://localhost:4000"
